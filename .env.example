# Supabase (from your project settings)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# For Edge Functions / backend only (never expose in client):
# SUPABASE_SERVICE_ROLE_KEY=...
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Platform cut from each paid sale (e.g. 15 = 15%). Set to whatever you want (e.g. 10–25).
# STRIPE_CONNECT_PLATFORM_FEE_PERCENT=15
