# Supabase (from your project settings — safe in the browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe publishable key (browser) — same test vs live mode as STRIPE_SECRET_KEY on the server.
# Required for embedded Checkout in the app. Dashboard → Developers → API keys → Publishable key.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Database password (Dashboard → Settings → Database). Used by Supabase CLI (db push, db pull).
# Do not commit real values — copy this file to .env and fill in locally.
SUPABASE_DB_PASSWORD=

# Your deployed app origin (no trailing slash). Used by Edge Functions for Stripe return URLs.
# Local: http://localhost:5173  |  Production: https://your-domain.com
# VITE_ prefix not required — this is for Supabase Edge Function secrets only.
# FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# The following are NOT in .env for the Vite app. Set them as Supabase
# Edge Function secrets (Dashboard → Project Settings → Edge Functions → Secrets)
# or:  npx supabase secrets set KEY=value --project-ref <ref>
# ---------------------------------------------------------------------------
#
# SUPABASE_SERVICE_ROLE_KEY   — Project Settings → API → service_role (keep secret)
# SUPABASE_URL                — same as VITE_SUPABASE_URL (often injected automatically)
#
# Stripe (one account = you / the platform; sellers connect via Connect Express)
# STRIPE_SECRET_KEY           — Developers → API keys → Secret key (sk_test_… or sk_live_…)
# STRIPE_WEBHOOK_SECRET       — Developers → Webhooks → your endpoint → Signing secret (whsec_…)
# STRIPE_CONNECT_PLATFORM_FEE_PERCENT — whole number, e.g. 10 = 10% platform fee on each sale
# FRONTEND_URL                — must match where users open the app (see above)
